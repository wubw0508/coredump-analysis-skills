#=============================================================================
# 循环流程配置文件
# 用于配置 dde-session-ui 崩溃分析流程的各项参数
#=============================================================================

# === Gerrit 配置 ===
# 是否自动提交到Gerrit
AUTO_SUBMIT_GERRIT="false"

# Gerrit目标分支（用于创建修复分支或提交）
GERRIT_TARGET_BRANCH="master"
# GERRIT_TARGET_BRANCH="develop/eagle"

# Gerrit审查者列表（逗号分隔）
GERRIT_REVIEWERS="ut000168"

# === 版本过滤配置 ===
# 最小崩溃次数阈值（低于此值的版本不分析）
MIN_CRASH_COUNT="5"

# 高崩溃次数阈值（用于标记高优先级版本）
HIGH_CRASH_THRESHOLD="50"

# 中崩溃次数阈值（用于标记中优先级版本）
MEDIUM_CRASH_THRESHOLD="20"

# === 分析配置 ===
# 每个版本最多分析的崩溃数量
MAX_CRASHES_PER_VERSION="50"

# 是否跳过版本同步（仅代码分析）
SKIP_VERSION_SYNC="false"

# 是否跳过崩溃分析（仅同步）
SKIP_CRASH_ANALYSIS="false"

# === 性能配置 ===
# 并行分析版本数（1=串行，>1=并行，暂未实现并行）
MAX_PARALLEL_VERSIONS="1"

# 版本同步超时时间（秒）
VERSION_SYNC_TIMEOUT="300"

# 崩溃分析超时时间（秒）
CRASH_ANALYSIS_TIMEOUT="600"

# === 输出配置 ===
# 是否生成对比图表（需要matplotlib等依赖）
GENERATE_CHARTS="false"

# 是否生成详细的堆栈跟踪
GENERATE_FULL_STACK="true"

# 是否保存中间结果
SAVE_INTERMEDIATE_RESULTS="true"

# === 进续续配置 ===
# 是否生成进度文件（用于中断后继续）
GENERATE_PROGRESS_FILE="true"

# 进度文件路径
PROGRESS_FILE="\${WORKSPACE}/loop_progress.json"

# === 包下载配置 ===
# 是否在分析前预先下载所有版本的包
PRE_download_ALL_PACKAGES="true"

# 包下载目录
PACKAGE_DOWNLOAD_DIR="\${WORKSPACE}/4.包管理/下载包"

# 包服务器地址（默认使用内部服务器）
INTERNAL_SERVER_URL="http://10.0.32.60:5001"

# === 日志配置 ===
# 是否启用详细日志
ENABLE_VERBOSE_LOG="false"

# 日志文件路径
LOG_FILE="\${WORKSPACE}/loop_analysis.log"

# === 工作目录配置 ===
# 工作目录基础路径（默认：./workspace）
# 可以通过 --workspace 参数覆盖
WORKSPACE="\${WORKSPACE:-./workspace}"

# === 其他配置 ===
# 是否在开始前确认
CONFIRM_BEFORE_START="true"

# 完成后是否显示摘要
SHOW_SUMMARY_AFTER_COMPLETE="true"

# 清理模式：never, error, success, always
CLEANUP_MODE="never"
