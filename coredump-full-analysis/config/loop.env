#=============================================================================
# Legacy / experimental loop flow config
#=============================================================================
# 本文件仅供旧的 loop / retry / 手工调试链路参考，不代表当前主入口默认值。
# 当前主入口默认行为请以：
#   - run_analysis_agent.sh
#   - coredump-full-analysis/scripts/analyze_crash_complete.sh
# 为准。
#
# 主链路当前关键默认值：
#   - 目标分支: develop/eagle
#   - 每版本最大 crash 数: 0（分析全部）
#   - enhanced addr2line 帧数: 300
#   - workspace: 自动创建时间戳目录
#
# 如果旧 loop 流程仍需使用，建议显式传参，不要假定它与主链路完全一致。
#=============================================================================

# === Gerrit 配置 ===
AUTO_SUBMIT_GERRIT="false"
GERRIT_TARGET_BRANCH="develop/eagle"
GERRIT_REVIEWERS="ut000168"

# === 版本过滤配置 ===
MIN_CRASH_COUNT="5"
HIGH_CRASH_THRESHOLD="50"
MEDIUM_CRASH_THRESHOLD="20"

# === 分析配置 ===
# 与主链路对齐：0 = 分析全部去重后的 crash
MAX_CRASHES_PER_VERSION="0"

# 旧 loop 流程内部可能仍有自己的深度控制；主链路默认 300
ADDR2LINE_MAX_FRAMES="300"

SKIP_VERSION_SYNC="false"
SKIP_CRASH_ANALYSIS="false"

# === 性能配置 ===
# 旧 loop 脚本当前仍按串行为主；并行参数保留但未形成主链路能力
MAX_PARALLEL_VERSIONS="1"
VERSION_SYNC_TIMEOUT="300"
CRASH_ANALYSIS_TIMEOUT="600"

# === 输出配置 ===
GENERATE_CHARTS="false"
GENERATE_FULL_STACK="true"
SAVE_INTERMEDIATE_RESULTS="true"

# === 进度/续跑配置 ===
GENERATE_PROGRESS_FILE="true"
PROGRESS_FILE="${WORKSPACE}/loop_progress.json"

# === 包下载配置 ===
# 保留历史变量名，避免旧脚本读取失败
PRE_download_ALL_PACKAGES="true"
PACKAGE_DOWNLOAD_DIR="${WORKSPACE}/4.包管理/downloads"
INTERNAL_SERVER_URL="http://10.0.32.60:5001"

# === 日志配置 ===
ENABLE_VERBOSE_LOG="false"
LOG_FILE="${WORKSPACE}/loop_analysis.log"

# === 工作目录配置 ===
# 仅供旧 loop 脚本回退使用；主入口会自动生成时间戳 workspace
WORKSPACE="${WORKSPACE:-./workspace}"

# === 其他配置 ===
CONFIRM_BEFORE_START="true"
SHOW_SUMMARY_AFTER_COMPLETE="true"
CLEANUP_MODE="never"
